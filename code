const COLORS = {
  marigold:'#FFB020', amber2:'#FF7A45', teal:'#2DD4BF', coral:'#FB6F84', violet:'#A78BFA', blue:'#60A5FA',
  paper:'#F6F4EE', muted:'#9295AE', line:'rgba(255,255,255,0.07)'
