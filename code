// ---------- Model table ----------
let sortKey = 'first_date', sortDir = 1;
let rows = DATA.model_stats.slice();

function renderTable(){
  const q = document.getElementById('searchBox').value.toLowerCase();
  const catF = document.getElementById('categoryFilter').value;
  let filtered = rows.filter(r => r.Model_Name.toLowerCase().includes(q) && (catF==='all' || r.category===catF));
  filtered.sort((a,b)=>{
    let va=a[sortKey], vb=b[sortKey];
    if(typeof va === 'string'){ return sortDir * va.localeCompare(vb); }
    return sortDir * (va-vb);
  });
  const maxDisc = Math.max(...rows.map(r=>r.avg_discount));
  const top3Disc = new Set([...rows].sort((a,b)=>b.avg_discount-a.avg_discount).slice(0,3).map(r=>r.Model_Name));
  document.getElementById('modelTableBody').innerHTML = filtered.map(r => `
    <tr>
      <td class="name">${r.Model_Name}</td>
      <td><span class="pill ${r.category}">${r.category}</span></td>
      <td>${r.first_date}</td>
      <td>$${r.launch_price}</td>
      <td>$${r.avg_current_price}</td>
      <td><span class="disc-bar-bg"><span class="disc-bar" style="width:${(r.avg_discount/maxDisc*100).toFixed(0)}%"></span></span>${r.avg_discount}%${top3Disc.has(r.Model_Name) ? `<span class="flame">${ICONS.flame}</span>` : ''}</td>
      <td>${r.avg_rating} ★</td>
      <td>${fmtInt(r.total_reviews)}</td>
    </tr>
  `).join('');
}
document.getElementById('searchBox').addEventListener('input', renderTable);
document.getElementById('categoryFilter').addEventListener('change', renderTable);
document.querySelectorAll('th[data-key]').forEach(th=>{
  th.addEventListener('click', ()=>{
    const key = th.dataset.key;
    if(sortKey === key){ sortDir *= -1; } else { sortKey = key; sortDir = 1; }
    renderTable();
  });
});
renderTable();
</script>
