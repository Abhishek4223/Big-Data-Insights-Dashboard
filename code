const months = DATA.monthly_price_by_category.YearMonth;
const cats = ['iPhone','iPad','Mac','Watch'];
let activeCats = new Set(cats);

const toggleDiv = document.getElementById('catToggle');
toggleDiv.innerHTML = cats.map(c=>`<button data-cat="${c}" class="active">${c}</button>`).join('');

const priceChart = new Chart(document.getElementById('priceTrendChart'), {
  type:'line',
  data:{
    labels: months,
    datasets: cats.map(c => ({
      label:c,
      data: DATA.monthly_price_by_category[c],
      borderColor: CAT_COLORS[c],
      backgroundColor: CAT_COLORS[c],
      spanGaps:true, tension:0.3, borderWidth:2.5, pointRadius:0, pointHoverRadius:4
    }))
  },
  options:{
    responsive:true, maintainAspectRatio:false,
    interaction:{ mode:'index', intersect:false },
    plugins:{ legend:{display:false}, tooltip:{
      backgroundColor:'#1A1C2C', borderColor:'#2E3050', borderWidth:1, padding:10,
      titleFont:{family:MONO, size:11}, bodyFont:{family:MONO, size:12},
      callbacks:{ label: c => `${c.dataset.label}: $${c.parsed.y}` } } },
    scales:{
      x:{ grid:{display:false}, ticks:{ maxTicksLimit:8, font:{family:MONO, size:10} } },
      y:{ grid:{ color: COLORS.line }, ticks:{ callback:v=>'$'+v, font:{family:MONO, size:10} } }
    }
  }
});
toggleDiv.querySelectorAll('button').forEach(btn=>{
  const c = btn.dataset.cat;
  btn.style.background = CAT_COLORS[c]; btn.style.color = '#0E0F16'; btn.style.borderColor = CAT_COLORS[c];
  btn.addEventListener('click', ()=>{
    if(activeCats.has(c)){ activeCats.delete(c); btn.classList.remove('active'); btn.style.background='transparent'; btn.style.color='var(--muted)'; btn.style.borderColor='var(--line)'; }
    else{ activeCats.add(c); btn.classList.add('active'); btn.style.background=CAT_COLORS[c]; btn.style.color='#0E0F16'; btn.style.borderColor=CAT_COLORS[c]; }
    priceChart.data.datasets.forEach(ds=>{ ds.hidden = !activeCats.has(ds.label); });
    priceChart.update();
  });
});

